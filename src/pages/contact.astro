---
import Base from "../layouts/Base.astro";

const email = "hello@emmanuelantony.com";

const socials = [
  {
    label: "GitHub",
    href: "https://github.com/emmanuelantony2000",
    path: "M12 1.5A10.5 10.5 0 0 0 8.7 22a.55.55 0 0 0 .73-.53v-1.9c-2.9.63-3.52-1.4-3.52-1.4-.48-1.2-1.16-1.53-1.16-1.53-.95-.65.07-.64.07-.64 1.05.07 1.6 1.08 1.6 1.08.94 1.6 2.45 1.14 3.05.87.1-.68.37-1.14.66-1.4-2.32-.27-4.76-1.16-4.76-5.16 0-1.14.41-2.07 1.07-2.8-.1-.27-.46-1.33.1-2.77 0 0 .88-.28 2.88 1.07a9.9 9.9 0 0 1 5.24 0c2-1.35 2.87-1.07 2.87-1.07.57 1.44.21 2.5.1 2.77.67.73 1.07 1.66 1.07 2.8 0 4.01-2.44 4.88-4.77 5.14.38.33.71.97.71 1.96v2.9c0 .29.2.62.74.52A10.5 10.5 0 0 0 12 1.5Z",
  },
  {
    label: "X",
    href: "https://x.com/emmanuelantony5",
    path: "M17.5 3h3l-7 8 8.2 10h-6.4l-5-6.1L7.8 21H4.7l7.4-8.5L4.2 3h6.5l4.5 5.6L17.5 3Zm-1.1 16h1.7L8.3 4.8H6.5L16.4 19Z",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/emmanuel-antony",
    path: "M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm6 0h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.5 4.78 5.76V21h-4v-5.3c0-1.27-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V21H9V9Z",
  },
];
---

<Base
  title="Emmanuel Antony | Contact"
  description="Have a project, a hard systems problem, or just want to trade notes on Rust? My inbox is open."
  image="/og/contact.png"
  imageAlt="Get in touch with Emmanuel Antony — email, GitHub, X, and LinkedIn."
  imageWidth={1200}
  imageHeight={630}
>
  <section class="flex min-h-[calc(100svh-14rem)] flex-col items-center justify-center px-2 py-12 text-center">
    <div class="inline-flex items-center gap-2.5 rounded-full border border-border/50 bg-background/70 px-3.5 py-1.5 text-sm font-medium text-muted-foreground backdrop-blur">
      <span class="h-2 w-2 rounded-full bg-emerald-500 shadow-[0_0_0_3px_rgba(65,199,119,0.18),0_0_8px_1px_rgba(65,199,119,0.5)]"></span>
      Open to interesting problems
    </div>

    <h1 class="mt-6 mb-4 max-w-3xl text-balance text-[clamp(2.4rem,4.4vw,3.6rem)] font-bold leading-[1.04] tracking-[-0.03em]">
      Let’s build something resilient.
    </h1>

    <p class="mb-9 max-w-[36ch] text-pretty text-[clamp(1.05rem,1.4vw,1.3rem)] leading-relaxed text-muted-foreground">
      Have a project, a hard systems problem, or just want to trade notes on Rust? My inbox is open.
    </p>

    <a
      href={`mailto:${email}`}
      class="inline-flex max-w-full items-center gap-1.5 rounded-full bg-primary px-3.5 py-3 text-[13px] font-medium text-primary-foreground shadow-sm transition hover:shadow-md sm:gap-2.5 sm:px-6 sm:text-base"
    >
      <svg class="h-[19px] w-[19px] shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="4.5" width="19" height="15" rx="2.5"/><path d="m3 6 9 6 9-6"/></svg>
      <span class="truncate">{email}</span>
      <span
        id="copy-email"
        role="button"
        tabindex="0"
        aria-label="Copy email address"
        title="Copy email address"
        data-email={email}
        class="-mr-1 shrink-0 rounded-full p-1 opacity-55 transition hover:opacity-100 focus-visible:opacity-100"
      >
        <svg id="copy-icon" class="h-[18px] w-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
        <svg id="copy-check" class="hidden h-[18px] w-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </span>
    </a>

    <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
      {socials.map((social) => (
        <a
          href={social.href}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background/40 px-5 py-2.5 text-sm font-medium transition hover:border-foreground/40"
        >
          <svg class="h-[18px] w-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d={social.path} /></svg>
          {social.label}
        </a>
      ))}
    </div>
  </section>
</Base>

<script is:inline>
  function setupCopyEmail() {
    const copy = document.getElementById("copy-email");
    if (!copy || copy.dataset.bound) return;
    copy.dataset.bound = "true";

    let timeout;
    function doCopy(event) {
      event.preventDefault();
      event.stopPropagation();
      const email = copy.dataset.email || "";
      navigator.clipboard.writeText(email).then(() => {
        document.getElementById("copy-icon")?.classList.add("hidden");
        document.getElementById("copy-check")?.classList.remove("hidden");
        clearTimeout(timeout);
        timeout = setTimeout(() => {
          document.getElementById("copy-icon")?.classList.remove("hidden");
          document.getElementById("copy-check")?.classList.add("hidden");
        }, 1600);
      });
    }

    copy.addEventListener("click", doCopy);
    copy.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") doCopy(event);
    });
  }

  setupCopyEmail();
  document.addEventListener("astro:after-swap", setupCopyEmail);
</script>
