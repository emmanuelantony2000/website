---
import TocList from "./TocList.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Only show h2 and h3, mirroring the desktop TOC
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <details
    id="toc-mobile"
    class="group sticky top-3 z-30 mb-9 overflow-hidden rounded-2xl border border-border bg-background/85 shadow-lg shadow-black/10 backdrop-blur-md xl:hidden"
    data-pagefind-ignore
  >
    <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3.5 text-[15px] font-medium [&::-webkit-details-marker]:hidden">
      <span class="flex min-w-0 flex-1 items-center gap-1.5">
        <span class="shrink-0">On this page</span>
        <span id="toc-mobile-current" class="min-w-0 truncate font-normal text-muted-foreground"></span>
      </span>
      <svg
        class="h-[18px] w-[18px] shrink-0 text-muted-foreground transition-transform duration-200 group-open:rotate-180"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      ><path d="m6 9 6 6 6-6" /></svg>
    </summary>
    <div class="max-h-[56vh] overflow-y-auto border-t border-border px-4 pt-2 pb-3">
      <TocList headings={filtered} />
    </div>
  </details>
)}

<script>
  function setupTocMobile() {
    const root = document.getElementById("toc-mobile");
    if (!root) return;

    const currentLabel = document.getElementById("toc-mobile-current");

    function setLabel(text: string) {
      if (currentLabel) currentLabel.textContent = text ? `· ${text}` : "";
    }

    // Initialize from the shared scroll-spy's last computed value
    const list = root.querySelector<HTMLElement>(".toc-list-root");
    setLabel(list?.dataset.activeText ?? "");

    const onActiveChange = (event: Event) => {
      setLabel((event as CustomEvent<{ text: string }>).detail.text);
    };
    document.addEventListener("toc-active-change", onActiveChange);

    // Tapping a link jumps to the section and collapses the accordion
    root.querySelectorAll<HTMLAnchorElement>(".toc-link").forEach((link) => {
      link.addEventListener("click", () => root.removeAttribute("open"));
    });

    document.addEventListener(
      "astro:before-swap",
      () => {
        document.removeEventListener("toc-active-change", onActiveChange);
      },
      { once: true },
    );
  }

  setupTocMobile();
  document.addEventListener("astro:after-swap", setupTocMobile);
</script>
